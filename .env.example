NODE_ENV=development

# Neon: pooled URL for the API, direct URL for Prisma migrations.
DATABASE_URL=postgresql://user:password@project-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:password@project.region.aws.neon.tech/neondb?sslmode=require
TAVILY_API_KEY=

API_HOST=0.0.0.0
API_PORT=3001
WEB_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
WEEK1_API_BASE_URL=http://localhost:3001

VITE_API_BASE_URL=http://127.0.0.1:3001

# Sui network and published Move objects.
# Populate these after running: sui client publish --network testnet
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_PACKAGE_ID=
NEXT_PUBLIC_SUI_PACKAGE_ID_TESTNET=
NEXT_PUBLIC_SUI_PACKAGE_ID_MAINNET=
NEXT_PUBLIC_CORE_REGISTRY_ID=
NEXT_PUBLIC_CORE_CONFIG_ID=
NEXT_PUBLIC_ARTIFACT_REGISTRY_ID=

# Optional bootstrap artifact values emitted by a Sui transaction.
EXCEL_ARTIFACT_ONCHAIN_ID=
EXCEL_ARTIFACT_REGISTRATION_TX=

AGENT_MODEL_MODE=openai-compatible
AGENT_MODEL_NAME=minimax-m2.5
# Oxlo provides OpenAI-compatible chat/tool-calling and embedding endpoints.
# Keep API keys backend-only; never expose them through VITE_* variables.
AGENT_MODEL_BASE_URL=https://api.oxlo.ai/v1
AGENT_MODEL_API_KEY=
AGENT_EMBEDDING_MODEL=bge-large
AGENT_EMBEDDING_DIMENSIONS=1024

# Legacy benchmark-agent Walrus settings. The persistent Neon artifact flow does not use Walrus.
WALRUS_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_AGENT_PRIVATE_KEY=
WALRUS_DEFAULT_EPOCHS=3
WALRUS_UPLOAD_RELAY_URL=
WALRUS_PUBLISHER_URL=
WALRUS_AGGREGATOR_URL=
SUI_PACKAGE_ID=
ARTIFACT_REGISTRY_ID=

AGENT_BENCHMARK_PATH=apps/agent/fixtures/support-benchmark.json
AGENT_OUTPUT_DIR=apps/agent/runs
AGENT_ARTIFACT_LIBRARY_DIR=apps/agent/knowledge
AGENT_ARTIFACT_MANIFEST_PATH=apps/agent/knowledge/manifest.json
AGENT_MIN_CONFIDENCE=0.72
AGENT_RETRIEVAL_LIMIT=2
AGENT_RETRIEVAL_MIN_SCORE=1
AGENT_PUSH_TO_PLATFORM=false
AGENT_REGISTER_DATASET_VERSION=false
AGENT_PLATFORM_API_URL=http://localhost:3001
AGENT_PLATFORM_CREATOR_ADDRESS=0x1234567890abcdef1234567890abcdef12345678
AGENT_PLATFORM_SUBMITTER_ADDRESS=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
AGENT_PLATFORM_REGISTRAR_ADDRESS=0xbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
AGENT_PLATFORM_DATASET_ID=
