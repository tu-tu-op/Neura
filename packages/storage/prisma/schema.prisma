generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AgentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum ArtifactStatus {
  DRAFT
  PUBLISHING
  PUBLISHED
  ARCHIVED
}

model Agent {
  id               String          @id @default(cuid())
  name             String
  instructions     String
  model            String
  status           AgentStatus     @default(DRAFT)
  enabledTools     String[]
  maxSteps         Int             @default(5)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  runs             AgentRun[]
  artifacts        AgentArtifact[]
}

model AgentRun {
  id          String         @id @default(cuid())
  agentId     String
  agent       Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status      AgentRunStatus @default(RUNNING)
  input       String
  output      String?
  error       String?
  usage       Json?
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  steps       AgentRunStep[]
  citations   RunCitation[]
  feedback    RunFeedback[]

  @@index([agentId, startedAt])
}

model AgentRunStep {
  id         String   @id @default(cuid())
  runId      String
  run        AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  position   Int
  kind       String
  toolName   String?
  input      Json?
  output     Json?
  error      String?
  durationMs Int?
  createdAt  DateTime @default(now())

  @@unique([runId, position])
}

model RunCitation {
  id        String   @id @default(cuid())
  runId     String
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  title     String
  url       String
  snippet   String
  createdAt DateTime @default(now())

  @@index([runId])
}

model RunFeedback {
  id              String   @id @default(cuid())
  runId           String
  run             AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  rating          Int
  correctedAnswer String?
  createdAt       DateTime @default(now())
}

model KnowledgeArtifact {
  id          String            @id @default(cuid())
  title       String
  domain      String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  versions    ArtifactVersion[]
  agents      AgentArtifact[]
}

model ArtifactVersion {
  id                String            @id @default(cuid())
  artifactId        String
  artifact          KnowledgeArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  version           Int
  status            ArtifactStatus    @default(DRAFT)
  content           String
  contentHash       String
  metadata          Json?
  suiObjectId       String?
  transactionDigest String?
  publishedAt       DateTime?
  createdAt         DateTime          @default(now())
  chunks            ArtifactChunk[]

  @@unique([artifactId, version])
  @@index([artifactId, status])
}

model ArtifactChunk {
  id                String            @id @default(cuid())
  artifactVersionId String
  artifactVersion   ArtifactVersion   @relation(fields: [artifactVersionId], references: [id], onDelete: Cascade)
  position          Int
  content           String
  searchText        String
  embedding         Unsupported("vector(1024)")?

  @@unique([artifactVersionId, position])
}

model AgentArtifact {
  agentId    String
  artifactId String
  agent      Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  artifact   KnowledgeArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@id([agentId, artifactId])
}

enum DatasetEntrySourceType {
  TASK
  CORRECTION
}

model PlatformConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskRecord {
  id              String             @id @default(cuid())
  taskId          String             @unique
  creatorAddress  String
  createdAt       DateTime
  metadataUri     String?
  metadataHash    String?
  chainId         Int?
  contractAddress String?
  transactionHash String?
  blockNumber     BigInt?
  logIndex        Int?
  corrections     CorrectionRecord[]
  datasetEntries  DatasetEntry[]
  insertedAt      DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([creatorAddress, createdAt])
}

model CorrectionRecord {
  id                String            @id @default(cuid())
  correctionId      String            @unique
  taskRecordId      String
  taskRecord        TaskRecord        @relation(fields: [taskRecordId], references: [id], onDelete: Restrict)
  submitterAddress  String
  submittedAt       DateTime
  metadataUri       String?
  metadataHash      String?
  chainId           Int?
  contractAddress   String?
  transactionHash   String?
  blockNumber       BigInt?
  logIndex          Int?
  datasetEntries    DatasetEntry[]
  insertedAt        DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([taskRecordId, submittedAt, correctionId])
}

model Dataset {
  id                  String           @id @default(cuid())
  datasetId           String           @unique
  createdBy           String
  createdAt           DateTime
  metadataUri         String?
  metadataHash        String?
  latestVersionNumber Int              @default(0)
  versions            DatasetVersion[]
  insertedAt          DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([createdBy, createdAt])
}

model DatasetVersion {
  id              String         @id @default(cuid())
  datasetRefId    String
  dataset         Dataset        @relation(fields: [datasetRefId], references: [id], onDelete: Restrict)
  versionNumber   Int
  registeredBy    String
  registeredAt    DateTime
  metadataUri     String?
  metadataHash    String?
  immutableRef    String
  chainId         Int?
  contractAddress String?
  transactionHash String?
  blockNumber     BigInt?
  logIndex        Int?
  entries         DatasetEntry[]
  insertedAt      DateTime       @default(now())

  @@unique([datasetRefId, versionNumber])
  @@index([datasetRefId, versionNumber])
}

model DatasetEntry {
  id                 String                 @id @default(cuid())
  datasetVersionId   String
  datasetVersion     DatasetVersion         @relation(fields: [datasetVersionId], references: [id], onDelete: Restrict)
  sourceType         DatasetEntrySourceType
  position           Int
  taskRecordId       String?
  taskRecord         TaskRecord?            @relation(fields: [taskRecordId], references: [id], onDelete: Restrict)
  correctionRecordId String?
  correctionRecord   CorrectionRecord?      @relation(fields: [correctionRecordId], references: [id], onDelete: Restrict)
  metadataUri        String?
  metadataHash       String?
  insertedAt         DateTime               @default(now())

  @@unique([datasetVersionId, position])
  @@index([taskRecordId])
  @@index([correctionRecordId])
}
